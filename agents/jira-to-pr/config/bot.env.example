# Copy this file to .env at the repository root and fill in all values.
# Never commit .env to version control.

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Jira bot user credentials
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BOT_EMAIL=ai-agent@brightlocal.com
JIRA_BOT_API_TOKEN=

# The bot user's Jira accountId — needed for the n8n assignee filter.
# Find it by running:
#   curl -u "$JIRA_BOT_EMAIL:$JIRA_BOT_API_TOKEN" \
#     "https://brightlocal.atlassian.net/rest/api/3/myself" | jq .accountId
JIRA_BOT_ACCOUNT_ID=

# GitHub Personal Access Token — needs scopes: repo (read+write), pull_requests
# Create at https://github.com/settings/tokens
GH_TOKEN=ghp_...

# Shared secret between n8n and this server.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
